---
import Layout from '@/layouts/Layout.astro';
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';

const products = [
  {
    name: 'SSLBoard',
    url: 'https://sslboard.com',
    hostname: 'sslboard.com',
    description: 'Certificate Lifecycle Management. Discover, monitor, and manage all your SSL/TLS certificates.',
    accentClass: 'border-t-amber-500',
  },
  {
    name: 'QCReady',
    url: 'https://qcready.com',
    hostname: 'qcready.com',
    description: 'Quality control automation for modern development teams.',
    accentClass: 'border-t-green-500',
  },
  {
    name: 'SSLCalendar',
    url: 'https://sslcalendar.com',
    hostname: 'sslcalendar.com',
    description: 'Never miss a certificate expiration again. A clear calendar view of your SSL landscape.',
    accentClass: 'border-t-blue-500',
  },
  {
    name: 'EzS3',
    url: 'https://ezs3.net',
    hostname: 'ezs3.net',
    description: 'Simple S3 bucket management. Browse, manage, and organize your cloud storage.',
    accentClass: 'border-t-purple-500',
  },
  {
    name: 'Chris Hartwig',
    url: 'https://chris-hartwig.com',
    hostname: 'chris-hartwig.com',
    description: 'Personal website and blog.',
    accentClass: 'border-t-rose-500',
  },
  {
    name: 'TwinBrix',
    url: 'https://twinbrix.app',
    hostname: 'twinbrix.app',
    description: 'A new way to work with building blocks.',
    accentClass: 'border-t-teal-500',
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Gone Coding Ltd.",
  "url": "https://gone-coding.com",
  "logo": "https://gone-coding.com/favicon.svg",
  "description": "Software engineering company based in Hong Kong, building developer tools and web infrastructure.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Unit 1603, The L. Plaza, 367-375 Queen's Road Central",
    "addressLocality": "Sheung Wan",
    "addressRegion": "Hong Kong",
    "addressCountry": "HK"
  },
  "sameAs": products.map(p => p.url)
};
---

<Layout title="We build software" description="Gone Coding Ltd. builds developer tools and web infrastructure from Hong Kong. Products include SSLBoard, QCReady, SSLCalendar, EzS3, and TwinBrix.">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <section class="mx-auto max-w-5xl px-6 pt-32 pb-20 text-center">
    <h1 class="text-5xl font-semibold tracking-normal sm:text-6xl lg:text-7xl">
      We build software.
    </h1>
    <p class="mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-muted-foreground">
      Gone Coding Ltd. is a software engineering company based in Hong Kong, building tools for the modern web.
    </p>
  </section>

  <section aria-labelledby="products-heading" class="mx-auto max-w-5xl px-6 pb-24">
    <h2 id="products-heading" class="sr-only">Products</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {products.map((product) => (
        <a
          href={product.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block"
          aria-label={`${product.name} — ${product.description}`}
        >
          <Card className={`border-t-2 ${product.accentClass} h-full transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg`}>
            <CardHeader>
              <CardTitle className="text-lg font-semibold group-hover:text-foreground/80">
                {product.name}
              </CardTitle>
              <CardDescription className="text-xs">
                {product.hostname}
              </CardDescription>
            </CardHeader>
            <CardContent>
              <p class="text-sm leading-relaxed text-muted-foreground">
                {product.description}
              </p>
            </CardContent>
          </Card>
        </a>
      ))}
    </div>
  </section>

  <section aria-labelledby="about-heading" class="mx-auto max-w-5xl px-6 pb-24">
    <div class="rounded-xl border bg-card p-8">
      <h2 id="about-heading" class="text-2xl font-semibold tracking-normal">About</h2>
      <p class="mt-4 max-w-2xl leading-relaxed text-muted-foreground">
        Gone Coding Ltd. is a software engineering company based in Hong Kong.
        We focus on developer tools and web infrastructure, building products
        that help teams ship better software.
      </p>
      <div class="mt-6 flex flex-wrap gap-2">
        <Badge variant="secondary">Hong Kong</Badge>
        <Badge variant="secondary">Developer Tools</Badge>
        <Badge variant="secondary">Web Infrastructure</Badge>
      </div>
    </div>
  </section>
</Layout>
