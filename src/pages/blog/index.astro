---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Badge } from '@/components/ui/badge';
import { Card, CardContent } from '@/components/ui/card';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Gone Coding Blog",
  "url": "https://gone-coding.com/blog",
  "description": "Thoughts on security, developer tools, SSL/TLS, and building software by the team at Gone Coding Ltd.",
  "publisher": {
    "@type": "Organization",
    "name": "Gone Coding Ltd.",
    "url": "https://gone-coding.com"
  },
  "blogPost": posts.map(post => ({
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.pubDate.toISOString(),
    "url": `https://gone-coding.com/blog/${post.id.replace(/\.(md|mdx)$/, '')}/`,
  }))
};

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}
---

<Layout
  title="Blog"
  description="Articles on SSL certificate management, TLS security, developer tooling, and building software by the Gone Coding Ltd. Read about SSLBoard, developer tools philosophy, and the latest TLS landscape reports."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Blog</h1>
    <p class="mt-3 text-muted-foreground">Thoughts on security, developer tools, and building software.</p>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => {
        const slug = post.id.replace(/\.(md|mdx)$/, '');
        return (
          <a href={`/blog/${slug}/`} class="group" aria-label={post.data.title}>
            <Card className="h-full transition-shadow group-hover:shadow-md">
              {post.data.heroImage ? (
                <img
                  src={post.data.heroImage}
                  alt={`Thumbnail for ${post.data.title}`}
                  class="aspect-video w-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="aspect-video w-full bg-gradient-to-br from-primary/20 to-primary/5" role="presentation" />
              )}
              <CardContent className="space-y-3">
                <div class="space-y-1.5">
                  <h2 class="text-base font-semibold leading-snug tracking-tight group-hover:underline">
                    {post.data.title}
                  </h2>
                  <time datetime={post.data.pubDate.toISOString()} class="text-xs text-muted-foreground">
                    {formatDate(post.data.pubDate)}
                  </time>
                </div>
                <p class="text-sm leading-relaxed text-muted-foreground line-clamp-3">
                  {post.data.description}
                </p>
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 pt-1">
                    {post.data.tags.map((tag) => (
                      <Badge variant="secondary" className="text-[11px]">
                        {tag}
                      </Badge>
                    ))}
                  </div>
                )}
              </CardContent>
            </Card>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
