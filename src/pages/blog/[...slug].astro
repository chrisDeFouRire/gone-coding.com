---
import Layout from '@/layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { Badge } from '@/components/ui/badge';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const slug = post.id.replace(/\.(md|mdx)$/, '');
const postUrl = `https://gone-coding.com/blog/${slug}/`;

const ogImage = post.data.heroImage
  ? new URL(post.data.heroImage, Astro.site).href
  : new URL('/og-default.svg', Astro.site).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { "dateModified": post.data.updatedDate.toISOString() }),
  "url": postUrl,
  "image": ogImage,
  "author": {
    "@type": "Organization",
    "name": "Gone Coding Ltd.",
    "url": "https://gone-coding.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Gone Coding Ltd.",
    "url": "https://gone-coding.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://gone-coding.com/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": postUrl
  },
  "keywords": post.data.tags.join(', ')
};

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}
---

<Layout
  title={post.data.title}
  description={post.data.description}
  ogImage={ogImage}
  article={true}
  publishDate={post.data.pubDate}
  modifiedDate={post.data.updatedDate}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="mx-auto max-w-2xl px-6 py-16" itemscope itemtype="https://schema.org/BlogPosting">
    <meta itemprop="headline" content={post.data.title} />
    <meta itemprop="description" content={post.data.description} />
    <meta itemprop="mainEntityOfPage" content={postUrl} />
    <span itemprop="author" itemscope itemtype="https://schema.org/Organization">
      <meta itemprop="name" content="Gone Coding Ltd." />
    </span>
    <span itemprop="publisher" itemscope itemtype="https://schema.org/Organization">
      <meta itemprop="name" content="Gone Coding Ltd." />
    </span>

    <header class="space-y-6">
      {post.data.heroImage ? (
        <img
          src={post.data.heroImage}
          alt={`Cover image for ${post.data.title}`}
          class="aspect-video w-full overflow-hidden rounded-xl object-cover"
          itemprop="image"
        />
      ) : (
        <div class="aspect-video w-full rounded-xl bg-gradient-to-br from-primary/20 to-primary/5" role="presentation" />
      )}

      <div class="space-y-3">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl" itemprop="name">{post.data.title}</h1>
        <div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
          <time datetime={post.data.pubDate.toISOString()} itemprop="datePublished">
            {formatDate(post.data.pubDate)}
          </time>
          {post.data.updatedDate && (
            <>
              <span aria-hidden="true">&middot;</span>
              <time datetime={post.data.updatedDate.toISOString()} itemprop="dateModified">
                Updated {formatDate(post.data.updatedDate)}
              </time>
            </>
          )}
        </div>
        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {post.data.tags.map((tag) => (
              <Badge variant="secondary">{tag}</Badge>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="prose-custom mt-10" itemprop="articleBody">
      <Content />
    </div>

    <footer class="mt-16 border-t border-border/40 pt-8">
      <a
        href="/blog/"
        class="inline-flex items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground"
      >
        &larr; Back to blog
      </a>
    </footer>
  </article>
</Layout>

<style>
  .prose-custom :global(h2) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.375rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .prose-custom :global(h3) {
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .prose-custom :global(p) {
    margin-bottom: 1.25rem;
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-muted-foreground);
  }

  .prose-custom :global(strong) {
    font-weight: 600;
    color: var(--color-foreground);
  }

  .prose-custom :global(a) {
    color: var(--color-foreground);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.15s;
  }

  .prose-custom :global(a:hover) {
    opacity: 0.8;
  }

  .prose-custom :global(ul),
  .prose-custom :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose-custom :global(ul) {
    list-style-type: disc;
  }

  .prose-custom :global(ol) {
    list-style-type: decimal;
  }

  .prose-custom :global(li) {
    margin-bottom: 0.375rem;
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-muted-foreground);
  }

  .prose-custom :global(blockquote) {
    margin-bottom: 1.25rem;
    border-left: 3px solid var(--color-border);
    padding-left: 1rem;
    font-style: italic;
    color: var(--color-muted-foreground);
  }

  .prose-custom :global(code) {
    font-size: 0.875em;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    background-color: var(--color-muted);
    font-family: var(--font-mono, monospace);
  }

  .prose-custom :global(pre) {
    margin-bottom: 1.25rem;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    background-color: var(--color-muted);
  }

  .prose-custom :global(pre code) {
    padding: 0;
    background: none;
    font-size: 0.8125rem;
  }

  .prose-custom :global(hr) {
    margin: 2rem 0;
    border-color: var(--color-border);
  }

  .prose-custom :global(img) {
    margin-bottom: 1.25rem;
    border-radius: 0.5rem;
  }
</style>
